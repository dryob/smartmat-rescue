# 複製成 .env 後填入實際值:  cp .env.example .env

# 兩個容器各自的 LAN IP (macvlan)
# Deco DHCP 範圍: 192.168.68.50 ~ 192.168.69.250
# 用 DHCP 範圍上面的 .251/.252，不會被 Deco 派到

DNSMASQ_IP=192.168.69.251
SMARTMAT_IP=192.168.69.252

# dnsmasq 回給裝置的 IP
#   正式部署: = SMARTMAT_IP (裝置打 NAS 的 container)
#   dev 模式: = Windows LAN IP (例 192.168.68.227)，裝置打 Windows 本機 server
DNS_TARGET_IP=192.168.69.252

# --- MQTT / Home Assistant auto-discovery (optional) ---
# 留空 MQTT_HOST = 關閉 MQTT 橋接
# 有 HA + Mosquitto 的話:
#   MQTT_HOST=192.168.68.xx
#   MQTT_USER=your_user
#   MQTT_PASS=your_pass
# 其餘都有 sensible default:
#   MQTT_PORT=1883
#   MQTT_TOPIC_PREFIX=smartmat
#   MQTT_DISCOVERY=1
#   MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_HOST=
MQTT_USER=
MQTT_PASS=